{
    // Configura o formatador padrão para arquivos do Robot Framework
    "[robotframework]": {
        "editor.defaultFormatter": "d-biehl.robotcode"
    },
    "files.exclude": {
        "**/Sikuli_*": true,
        "**/sikuliximage*": true,
        "**/__pycache__": true,
        // "**/*.html": true,
        "**/*.log": true,
        "**/logs/*": true,
        // "**/venv": true,
        "**/*.xml": true,
        "**/.ruff_cache": true,
        "**/.pytest_cache": true,
    },
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,
}
